# =============================================================================
# AI DB Advisor — Docker environment
# Copy to .env (cp .env.docker.example .env), then choose ONE LLM option below.
#   docker compose up --build   ->   open http://localhost:8080
# =============================================================================

ENV=prod
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# LLM — pick exactly ONE of the options below (uncomment its lines)
# -----------------------------------------------------------------------------

# Option A) Your OWN Ollama already running on the host machine (DEFAULT).
#   Nothing extra to start — if Ollama is up on your PC, the app auto-connects.
#   (host.docker.internal points from the container back to your machine.)
LLM_PROVIDER=ollama
LLM_ENDPOINT=http://host.docker.internal:11434
LLM_MODEL=qwen2.5:7b-instruct
LLM_API_KEY=

# Option B) Bundled local Ollama (no host install, fully offline):
#   Start with:  docker compose --profile ollama up --build
#   Then pull a model:  docker compose exec ollama ollama pull qwen2.5:7b-instruct
# LLM_PROVIDER=ollama
# LLM_ENDPOINT=http://ollama:11434
# LLM_MODEL=qwen2.5:7b-instruct

# Option C) OpenAI or any OpenAI-compatible endpoint (LM Studio, vLLM, gateways):
# LLM_PROVIDER=openai
# LLM_ENDPOINT=https://api.openai.com
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...

# Option D) Anthropic (Claude):
# LLM_PROVIDER=anthropic
# LLM_ENDPOINT=https://api.anthropic.com
# LLM_MODEL=claude-sonnet-4-6
# LLM_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Connecting to databases on YOUR machine
# -----------------------------------------------------------------------------
# Inside the container, "localhost" means the container, not your PC. With the
# setting below (on by default in compose), you can still register datasources
# with localhost/127.0.0.1 — the backend rewrites the host to reach your machine.
# Set to false if your databases are remote and you never use localhost DSNs.
REWRITE_LOCALHOST_DSN=true
DSN_LOCALHOST_REPLACEMENT=host.docker.internal

# -----------------------------------------------------------------------------
# Optional: email / Slack alert notifications (leave blank to disable)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# MCP (optional, PostgreSQL only — off by default; UI shows demo mode if disabled)
# -----------------------------------------------------------------------------
MCP_ENABLED=false
MCP_ENDPOINT=http://localhost:3000
MCP_API_KEY=

# -----------------------------------------------------------------------------
# Monitoring (optional — Prometheus + Grafana + exporters)
#   Enable with:  docker compose --profile monitoring up --build
#   Grafana:    http://localhost:3001   Prometheus: http://localhost:9090
# -----------------------------------------------------------------------------
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
# DB the postgres-exporter scrapes (defaults to the sample UniversityDB on the host).
# Point this at your own database to monitor it instead.
PG_EXPORTER_DSN=postgresql://postgres:postgres@host.docker.internal:5432/UniversityDB?sslmode=disable

# -----------------------------------------------------------------------------
# Build options
# -----------------------------------------------------------------------------
# Set to 1 to also install SQL Server (pyodbc) + Oracle (oracledb) drivers in the image:
#   docker compose build --build-arg OPTIONAL_DB_DRIVERS=1
OPTIONAL_DB_DRIVERS=0
