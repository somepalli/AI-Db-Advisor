# =============================================================================
# AI DB Advisor - Environment Configuration Example
# =============================================================================
# Copy this file to .env and fill in your own values:
#   cp .env.example .env
# NEVER commit a real .env (it is git-ignored). Only this example is tracked.

# =============================================================================
# Backend server
# =============================================================================
API_HOST=127.0.0.1
API_PORT=8095
ENV=dev                 # dev or prod
LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR, CRITICAL

# =============================================================================
# LLM Configuration (Ollama)
# =============================================================================
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b-instruct
LLM_ENDPOINT=http://127.0.0.1:11434

# =============================================================================
# MCP (Model Context Protocol) Configuration  -- optional, PostgreSQL only
# =============================================================================
# Leave MCP_ENABLED=false to run without MCP (the UI shows a "demo mode" banner).
MCP_ENABLED=false
MCP_ENDPOINT=http://localhost:3000
MCP_API_KEY=
MCP_TIMEOUT=30
MCP_MAX_SUGGESTIONS=5
MCP_BRIDGE_PORT=3000
# DSN used by the postgres-mcp bridge (placeholder — use your own):
POSTGRES_DSN=postgresql://user:password@localhost:5432/your_database

# =============================================================================
# Email Notification Configuration (SMTP) -- optional
# =============================================================================
# For Gmail, generate an App Password (https://myaccount.google.com/security).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# =============================================================================
# Slack Notification Configuration (Incoming Webhook) -- optional
# =============================================================================
SLACK_WEBHOOK_URL=

# =============================================================================
# Analytics (DuckDB) -- optional, used by the cross-database analytics sync
# =============================================================================
# DUCKDB_DSN=duckdb:///analytics.db
