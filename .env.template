# =============================================================================
# AI DB Advisor - Environment Configuration Template
# =============================================================================
# Copy this file to .env and configure with your actual values
# cp .env.template .env

# =============================================================================
# LLM Configuration (Ollama)
# =============================================================================
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b-instruct
LLM_ENDPOINT=http://127.0.0.1:11434

# =============================================================================
# Email Notification Configuration (SMTP)
# =============================================================================
# For Gmail, you need to create an App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to App Passwords
# 4. Generate a new app password for "Mail"
# 5. Use that 16-character password below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=oncall@company.com,dba-team@company.com

# For other email providers:
# Microsoft Outlook/Office 365:
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#
# Yahoo Mail:
#   SMTP_HOST=smtp.mail.yahoo.com
#   SMTP_PORT=587
#
# Custom SMTP Server:
#   SMTP_HOST=mail.yourcompany.com
#   SMTP_PORT=587  # or 465 for SSL

# =============================================================================
# Slack Notification Configuration (Incoming Webhook)
# =============================================================================
# To create a Slack Incoming Webhook:
# 1. Go to https://api.slack.com/apps
# 2. Click "Create New App" → "From scratch"
# 3. Name it "AI DB Advisor" and select your workspace
# 4. In "Incoming Webhooks", toggle "Activate Incoming Webhooks" ON
# 5. Click "Add New Webhook to Workspace"
# 6. Select the channel where alerts should be posted
# 7. Copy the Webhook URL and paste below

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Example:
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXX

# =============================================================================
# MCP (Model Context Protocol) Configuration
# =============================================================================
MCP_ENABLED=true
MCP_ENDPOINT=http://localhost:3000
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/UniversityDB
MCP_BRIDGE_PORT=3000

# =============================================================================
# Application Configuration
# =============================================================================
ENV=dev  # dev or prod
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# =============================================================================
# Alert System Configuration (Optional Overrides)
# =============================================================================
# Override default alert evaluation interval (default: 30 seconds)
# ALERT_EVALUATION_INTERVAL=30

# Override notification cooldown (default: 15 minutes)
# ALERT_NOTIFICATION_COOLDOWN=15

# =============================================================================
# Database Configuration Examples
# =============================================================================
# These are registered via the UI, but you can reference them here for documentation

# PostgreSQL Example:
# postgresql://user:password@host:5432/database

# MySQL Example:
# mysql://user:password@host:3306/database

# SQL Server Example:
# mssql://user:password@host:1433/database

# Oracle Example:
# oracle://user:password@host:1521/service_name

# MongoDB Example:
# mongodb://user:password@host:27017/database

# Redis Example:
# redis://host:6379/0

# SQLite Example:
# sqlite:///path/to/database.db

# Cassandra Example:
# cassandra://host:9042/keyspace
