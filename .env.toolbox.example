# Toolbox server configuration (sample).
# Copy to .env.toolbox and replace ALL credentials before use.
TOOLBOX_IMAGE=us-central1-docker.pkg.dev/database-toolbox/toolbox/toolbox:0.18.0
TOOLBOX_PORT=5001
TOOLBOX_API_KEY=CHANGE_ME

# ClickHouse connection details for Toolbox
CLICKHOUSE_HOST=host.docker.internal
CLICKHOUSE_PORT=8123
CLICKHOUSE_PROTOCOL=http
CLICKHOUSE_DATABASE=ai_db_advisor
CLICKHOUSE_USER=toolbox_reader
CLICKHOUSE_PASSWORD=CHANGE_ME
